{
  "name": "governada-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint --cache",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:component": "vitest run --project component",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "sync": "tsx scripts/sync-dreps.ts",
    "seed:staging": "tsx scripts/seed-staging.ts",
    "smoke-test": "tsx scripts/smoke-test.ts",
    "inngest:status": "tsx scripts/inngest-status.ts",
    "posthog:check": "tsx scripts/posthog-check.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "inngest:dev": "npx inngest-cli@latest dev",
    "gen:types": "tsx scripts/gen-types.ts",
    "analyze": "ANALYZE=true next build --webpack",
    "format": "prettier --write .",
    "format:check": "prettier --cache --check .",
    "preflight": "run-p format:check lint type-check test",
    "preflight:quick": "run-p format:check lint type-check test:changed",
    "test:changed": "vitest run --changed",
    "prepare": "husky",
    "test:scoring": "vitest run __tests__/scoring/ __tests__/alignment/ __tests__/ghi/ __tests__/matching/",
    "test:visual": "playwright test e2e/visual-regression.spec.ts",
    "bundle-report": "tsx scripts/bundle-report.ts",
    "test:load": "k6 run tests/load/scenarios/citizen-journey.js",
    "test:load:api": "k6 run tests/load/scenarios/api-v1.js",
    "test:load:burst": "k6 run tests/load/scenarios/engagement-burst.js",
    "test:load:drep": "k6 run tests/load/scenarios/drep-workspace.js"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,css,yaml,yml}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "dependencies": {
