# Koios API Configuration
# API Key is optional - Koios offers free tier without authentication
# For higher rate limits, register at https://koios.rest/ and get an API key
KOIOS_API_KEY=

# Koios API Base URL (mainnet)
# Do not change unless using a different network or custom endpoint
NEXT_PUBLIC_KOIOS_BASE_URL=https://api.koios.rest/api/v1

# Admin wallets (comma-separated) for DRep dashboard access without being a DRep.
# Accepts payment addresses (addr1...) and/or stake addresses (stake1...).
# Stake addresses are recommended — they stay consistent across HD wallet address rotation.
ADMIN_WALLETS=

# Web Push Notifications (VAPID keys)
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@governada.io

# Supabase type generation (npm run gen:types)
# Get from: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=

# Upstash Redis (optional — falls back to Supabase for rate limiting)
# Create at: https://console.upstash.com/
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# PostHog query API (npm run posthog:check)
# Create at: https://us.posthog.com/settings/user-api-keys (needs Query Read permission)
# Project ID from: https://us.posthog.com/settings/project
POSTHOG_PERSONAL_API_KEY=
POSTHOG_PROJECT_ID=

# Dev mock auth (local testing only — never set in production)
# Enables /api/auth/dev-mock for adversarial review agents to test auth-gated flows
DEV_MOCK_AUTH=true

# BetterStack heartbeat URLs (external uptime monitoring)
# Create heartbeat monitors at: https://betterstack.com
HEARTBEAT_URL_PROPOSALS=
HEARTBEAT_URL_BATCH=
HEARTBEAT_URL_DAILY=
