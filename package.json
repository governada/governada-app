{
  "name": "drepscore-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "sync": "tsx scripts/sync-dreps.ts",
    "seed:staging": "tsx scripts/seed-staging.ts",
    "smoke-test": "tsx scripts/smoke-test.ts",
    "inngest:status": "tsx scripts/inngest-status.ts",
    "posthog:check": "tsx scripts/posthog-check.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "inngest:dev": "npx inngest-cli@latest dev",
    "gen:types": "tsx scripts/gen-types.ts",
    "analyze": "ANALYZE=true next build --webpack",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preflight": "run-p format:check lint type-check test",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,css,yaml,yml}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@icons-pack/react-simple-icons": "^13.11.2",
    "@meshsdk/core": "^1.9.0-beta.101",
    "@meshsdk/react": "^2.0.0-beta.2",
    "@react-email/components": "^1.0.8",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/postprocessing": "^3.0.4",
    "@sentry/nextjs": "^10.40.0",
    "@supabase/supabase-js": "^2.98.0",
    "@tanstack/react-query": "^5.90.21",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.3",
    "bech32": "^2.0.0",
    "blakejs": "^1.2.1",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "d3-array": "^3.2.4",
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0",
    "framer-motion": "^12.35.0",
    "fuse.js": "^7.1.0",
    "inngest": "^3.52.6",
    "jose": "^6.1.3",
    "lucide-react": "^0.577.0",
    "ml-matrix": "^6.12.1",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "posthog-js": "^1.356.1",
    "posthog-node": "^5.26.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "resend": "^6.9.3",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2",
    "ts-node": "^10.9.2",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.1.6",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/canvas-confetti": "^1.9.0",
    "@types/d3-array": "^3.2.2",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-shape": "^3.1.8",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.183.1",
    "@vitest/coverage-v8": "^3.2.4",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.2",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.1",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
