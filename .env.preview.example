# Preview environment template - copied into Railway preview env vars
# DO NOT fill real values here; this is a documentation template.

# Supabase (preview branch - auto-rotated per PR by Supabase preview integration)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# PostHog dev project (separate from prod)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# Cardano governance - preview env reads mainnet chain data read-only
KOIOS_API_KEY=
KOIOS_BASE_URL=https://api.koios.rest/api/v1

# Delegation mode - sandbox writes to preview Supabase only; mainnet submits on-chain.
# Preview defaults to sandbox; production is mainnet.
GOVERNADA_DELEGATION_MODE=sandbox

# Railway preview metadata (auto-injected by Railway)
RAILWAY_PUBLIC_DOMAIN=
RAILWAY_GIT_BRANCH=
RAILWAY_GIT_COMMIT_SHA=
