# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results
/playwright-report
/blob-report

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
response.json

# local IDE / agent settings
.vscode/
.cursor/
.mcp.json

# Claude Code - track commands, rules, agents, hooks, skills, settings; local overrides stay private
.claude/settings.local.json

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# supabase
supabase/.temp/

# typescript
*.tsbuildinfo

# linter/formatter caches
.eslintcache
next-env.d.ts
.env*.local

# Observable Framework
analytics/node_modules
analytics/.observablehq/cache
analytics/src/.observablehq/cache
analytics/dist
analytics/.env


# Bundle analyzer
.next/analyze/

# Cursor plans
.cursor/plans/

# Outreach data
outreach-claim-links.txt
outreach-contacts.csv
outreach-data.json

# Local scripts
scripts/trigger-sync.js

# Vercel local
.vercel/
analytics/.vercel/

# Temp commit/PR files
COMMIT_MSG*.txt
PR_BODY*.md

# Bundle baseline (machine-specific)
.bundle-baseline.json

# Agent artifacts (machine-specific, not for git)
.agents/
.claude/perf-snapshots/
.claude/infra-snapshots/
.claude/scheduled_tasks.lock
.claude/worktrees/
/.gh-cache/
/.codex-*
