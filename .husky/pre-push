#!/usr/bin/env sh
# Quick pre-push gate: catch obvious failures before wasting a CI round-trip.
# Full CI is still authoritative — this is a fast local filter.

# Type-check (incremental, ~3s with .tsbuildinfo cache)
npx tsc --noEmit 2>/dev/null || {
  echo "PRE-PUSH BLOCKED: TypeScript errors detected. Run 'npx tsc --noEmit' to see details."
  exit 1
}

# Lint only changed files that still exist (fast)
CHANGED_FILES=$(git diff --name-only --cached HEAD~1 2>/dev/null | grep -E '\.(ts|tsx)$' || true)
EXISTING_FILES=""
for f in $CHANGED_FILES; do
  [ -f "$f" ] && EXISTING_FILES="$EXISTING_FILES $f"
done
if [ -n "$EXISTING_FILES" ]; then
  echo "$EXISTING_FILES" | xargs npx eslint --cache --quiet 2>/dev/null || {
    echo "PRE-PUSH BLOCKED: ESLint errors in changed files."
    exit 1
  }
fi
