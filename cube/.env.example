# Cube.js Environment Configuration
# Copy to .env and fill in values

# Database (Supabase direct connection)
CUBEJS_DB_TYPE=postgres
CUBEJS_DB_HOST=db.pbfprhbaayvcrxokgicr.supabase.co
CUBEJS_DB_PORT=5432
CUBEJS_DB_NAME=postgres
CUBEJS_DB_USER=postgres
CUBEJS_DB_PASS=your-supabase-db-password
CUBEJS_DB_SSL=true

# API Security
CUBEJS_API_SECRET=your-cube-api-secret-min-32-chars

# SQL API (for BI tools)
CUBEJS_PG_SQL_PORT=15432
CUBEJS_SQL_USER=cube
CUBEJS_SQL_PASSWORD=your-sql-api-password

# Cube Store
CUBEJS_CUBESTORE_HOST=cubestore

# Runtime
CUBEJS_DEV_MODE=true
CUBEJS_SCHEMA_PATH=model
CUBEJS_TELEMETRY=false
